# === Environment Variables Template ===
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Google Gemini API Key (free tier: https://aistudio.google.com/app/apikey)
# Required only if using Gemini fallback
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Base URL (default: http://localhost:11434)
# Change if running Ollama on different host/port
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Hugging Face Token (for private models/gated datasets)
# HF_TOKEN=your_hf_token_here

# Optional: LangSmith API Key (for tracing/debugging)
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_PROJECT=rag-chatbot
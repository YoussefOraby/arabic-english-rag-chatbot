# === Environment Variables Template ===
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
#
# The app works out of the box with Ollama only — no env vars required.
# Only set these if you need the optional features below.

# ── Optional: Google Gemini Fallback ──────────────────────────────────
# Gemini is NOT required. The app defaults to Ollama (local LLM).
# Only set this if you want Gemini as an alternative LLM provider.
# Get a free API key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Ollama Customization ────────────────────────────────────
# Default: http://localhost:11434
# Change if running Ollama on a different host or port.
# OLLAMA_BASE_URL=http://localhost:11434

# ── Optional: Test Database Path ──────────────────────────────────────
# Used by pytest to isolate test data from production data.
# If not set, tests create a temporary directory automatically.
# DOCUMENTS_DB_PATH=data/processed/test_documents.db
